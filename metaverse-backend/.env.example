# Core
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/metabrainai?schema=public"
JWT_SECRET="replace-with-a-long-random-secret"
SESSION_SECRET="replace-with-another-long-random-secret"
PORT=3001
NODE_ENV=development
CORS_ORIGINS=http://localhost:3000
LOG_LEVEL=info

# AI / RAG
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
CHROMA_URL=http://localhost:8000
EMBEDDING_MODEL=Xenova/all-MiniLM-L6-v2
RAG_CHUNK_SIZE=512
RAG_CHUNK_OVERLAP=64

# Email (legacy auth)
SENDGRID_API_KEY=
REACT_APP_FRONTEND_URL=http://localhost:3000

# Web3 Store
ETH_RPC_URL=
STORE_TREASURY_ADDRESS=

# World
WORLD_VOICE_RADIUS=12

# Legacy MySQL (optional)
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=metabrain
